{
  "_comment": "Ready-to-paste mcpServers block for Claude Desktop — default personal deployment. The domain servers below ship in later milestones; clinicalai-mcp v0.1 milestone 1 delivers @openclinicalai/shared only.",
  "mcpServers": {
    "clinicalai-drugs": {
      "command": "npx",
      "args": ["-y", "@openclinicalai/drugs"],
      "env": {
        "OPENFDA_API_KEY": "<optional>",
        "DRUGBANK_API_KEY": "<optional>"
      }
    },
    "clinicalai-evidence": {
      "command": "npx",
      "args": ["-y", "@openclinicalai/evidence"],
      "env": {
        "NCBI_API_KEY": "<optional>"
      }
    },
    "clinicalai-calc": {
      "command": "npx",
      "args": ["-y", "@openclinicalai/calc"]
    },
    "clinicalai-terminologies": {
      "command": "npx",
      "args": ["-y", "@openclinicalai/terminologies"],
      "env": {
        "UMLS_API_KEY": "<optional>"
      }
    }
  }
}
