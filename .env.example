# clinical-mcp environment configuration
#
# Copy this file to `.env` and fill in any keys you have. The `.env` file is
# gitignored — secrets stay on your machine. The shared MCP scaffold loads
# this automatically on startup (see packages/shared/src/dotenv.ts), so every
# domain server picks up the same values without re-declaring them.
#
# Real OS-level env vars take precedence over .env values — if NCBI_API_KEY
# is already set in your shell or system env, the value here is ignored.
#
# IMPORTANT — TWO-TIER LICENSING REALITY (2026):
# As of 2026, Wolters Kluwer, Elsevier, and others have split clinical content
# licensing into two separate tiers: (1) API access and (2) AI/RAG/MCP-use
# rights ("Generative AI license"). A regular institutional API contract for
# Lexicomp or UpToDate is NOT sufficient to legally consume that content via
# this MCP suite — your institution also needs the GenAI license rider on top.
# Vendor slots below are annotated with which tier they require.
#
# See ARCHITECTURE.md §3.4 (license tiers) for which vendors to pursue.


# ===========================================================================
# Free — raises rate limits
# ===========================================================================

# PubMed eutils. Free key, raises rate from 3 to 10 req/sec.
# Register: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# openFDA. Free key, raises rate from 240/min to 120,000/day.
# Register: https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=


# ===========================================================================
# Free — requires registration but no payment
# ===========================================================================

# UMLS — SNOMED CT, cross-vocab mapping, ICD-10-CM enrichment.
# Free academic license, per-user registration required.
# https://uts.nlm.nih.gov/uts/signup-login
UMLS_API_KEY=

# USPSTF Prevention TaskForce API. Free but token-gated — email
# uspstfpda@ahrq.gov to request a token. Leave unset to use the bundled
# monthly snapshot (default). Set to enable live API mode.
# https://www.uspreventiveservicestaskforce.org/apps/api.jsp
USPSTF_API_TOKEN=


# ===========================================================================
# Licensed — REALISTIC at single-user / small-shop tier
# ===========================================================================
# These are the only vendors with a credible BYO path for individual
# clinicians or small clinical-AI shops. Everything else with a public name
# is enterprise-only — see the section below.

# DrugBank Clinical API.
# IMPORTANT — academic licensing reality (2026): DrugBank no longer issues
# academic / non-commercial licenses for the Clinical API. The Clinical API
# is now sales-gated commercial only. This slot is preserved for deployers
# who already hold (or will purchase) a commercial DrugBank license — for
# academic-friendly clinician-grade DDI, Lexicomp / Micromedex are the
# realistic targets (see the enterprise section below).
#
# Without DRUGBANK_API_KEY (the common case), `get_drug_interactions` falls
# back to surfacing the FDA label's "Drug Interactions" section per RxCUI —
# prose, not pairwise, but a real free interaction surface.
#
# Unlocks: structured pairwise DDI with severity / mechanism / management,
# enriched drug records.
# Tier reported in ToolResult: "licensed-drugbank"
# https://go.drugbank.com/data_packages
DRUGBANK_API_KEY=
DRUGBANK_API_BASE=                          # override if license routes through a non-default host

# DynaMed Infobutton — partial BYO via HL7 Infobutton CDS API, included
# with every DynaMed subscription including the ~$399/yr individual tier.
# This is a LIGHTWEIGHT context-aware lookup (code → recommendation), not
# a full-content RAG path. Full-content RAG against DynaMed requires a
# separate EBSCO redistribution agreement that is not available at
# individual tier.
#
# Status: SCAFFOLD ONLY in v0.1 — the env slots are reserved so policy
# files can attest to the license now, but the client wiring lands in a
# later milestone. Setting these today is a no-op aside from license
# detection.
#
# Unlocks (when client lands): Infobutton CDS lookups in
# @clinical-mcp/evidence and @clinical-mcp/terminologies.
# Tier reported in ToolResult: "licensed-dynamed-infobutton"
# https://developer.ebsco.com/medical-point-care-apis/dynamed
DYNAMED_INFOBUTTON_USER=
DYNAMED_INFOBUTTON_PROFILE=

# NEJM AI — open benchmark datasets and evaluation protocols. Free, no
# token required for the open benchmark suite. Used by our comparative-
# evaluation methodology.
# Article content is NOT accessible via this slot; this only enables the
# open benchmark/dataset endpoints.
# https://ai.nejm.org/about/products-and-services
NEJM_AI_BENCHMARKS_ENABLED=                 # "true" to enable benchmark integration


# ===========================================================================
# Licensed — ENTERPRISE-ONLY (requires institutional contract + GenAI rider)
# ===========================================================================
# These slots exist for institutional deployments where the org holds BOTH
# (1) an enterprise API contract with the vendor AND (2) the vendor's
# separate Generative AI license tier. Without both, leave these blank.
# Per ARCHITECTURE.md §3.4, the MCP refuses to call upstream with these
# keys if the deployment policy is `personal` — they are only active under
# the `covered_entity` policy with the AI rider explicitly attested in the
# policy YAML.

# Lexicomp / Lexidrug (Wolters Kluwer Clinical Drug Information).
# Requires: WK Digital Architect contract + Lexidrug Module + Generative AI
# license rider.
# Unlocks: clinician-grade DDI with severity / mechanism / management text,
# dosing guidance, drug monographs.
# Tier reported in ToolResult: "licensed-lexicomp"
# https://developer.wkhealth.com/getting_started
LEXICOMP_API_KEY=
LEXICOMP_API_BASE=

# Micromedex (Merative).
# Requires: institutional Micromedex contract + AI-use rider.
# Unlocks: clinician-grade DDI, IV compatibility data.
# Tier reported in ToolResult: "licensed-micromedex"
# https://www.merative.com/clinical-decision-support/micromedex
MICROMEDEX_API_KEY=
MICROMEDEX_API_BASE=


# ===========================================================================
# Vendor slots deliberately NOT included
# ===========================================================================
# - UpToDate: no realistic BYO path even at institutional tier. Wolters
#   Kluwer's "UpToDate Connect" CDS API is enterprise-only and content
#   redistribution into AI products is explicitly disallowed. Including a
#   slot would imply a path that doesn't exist.
# - ClinicalKey AI (Elsevier): T&Cs explicitly bar third-party AI training
#   or RAG over their content. Even institutional subscriptions don't
#   unlock a usable MCP integration path.
# - First Databank: no individual or small-shop tier; partner/OEM-only.
# - Epocrates: no public developer API exists.
# If any of these vendors changes their policy, add slots at that point.


# ===========================================================================
# Deployment policy + cache (ARCHITECTURE.md §3.5.3, §4.2)
# ===========================================================================
# CLINICAL_MCP_POLICY=personal              # personal | covered_entity | research_deid
# CLINICAL_MCP_POLICY_FILE=                 # absolute path to a custom policy YAML
# CLINICAL_CACHE_URL=                       # leave unset for default SQLite; or `none` to disable
# CLINICAL_CACHE_DIR=                       # override the default ~/.clinical-mcp cache dir
# CLINICAL_CACHE_ENCRYPTION_KEY=            # required when cache.persist_sensitive_inputs is true


# ===========================================================================
# PHI redaction backend (ARCHITECTURE.md §3.5.4)
# ===========================================================================
# Only set the keys for the backend(s) your policy YAML actually selects.
#
# READ THIS BEFORE USING A CLOUD FOUNDATION MODEL FOR PHI REDACTION:
# Sending PHI to Anthropic / OpenAI / any cloud foundation model is a HIPAA
# disclosure. To be compliant for a `covered_entity` deployment you MUST
# have BOTH of the following with the model provider:
#   1. A signed Business Associate Agreement (BAA) covering the API.
#      - Anthropic offers BAAs via Claude for Enterprise.
#      - OpenAI offers BAAs via the Enterprise / API ZDR program.
#   2. A non-retention / Zero Data Retention (ZDR) agreement — the provider
#      must contractually agree not to log, retain, or train on the PHI
#      submitted for redaction.
# Without BOTH, do NOT use the cloud foundation backend on real PHI.
#
# Empirical context (informal, from prior work — published numbers will
# come with the comparative evaluation):
#   - regex / pattern-only stacks: F1 collapses on clinical narrative
#   - smaller NER models (OpenMed, BioBERT-family) on out-of-domain
#     clinical text: F1 ≈ 0.1
#   - larger NER / older NLP stacks on out-of-domain: F1 ≈ 0.3–0.5
#   - frontier foundation models (Claude / GPT-4-class) out-of-the-box
#     with Safe Harbor prompt: F1 ≈ 0.75–0.9+ (no LoRA, no prompt tuning)
# The recall gap is why `foundation` is recommended for `covered_entity`,
# despite the compliance cost. If a BAA is not available, the realistic
# alternatives are: (a) run a strong local model via Ollama (Llama 3.1 70B+
# or similar — a Mac mini cluster works but is expensive), (b) fine-tune
# a smaller open-weights model on a labeled redaction set (engineering-
# heavy), or (c) cap PHI use to the `personal` policy with `regex`+`safe`
# pattern warnings and accept the recall limitation.

# Cloud foundation backends — REQUIRE BAA + ZDR (see above) before use on
# real PHI under `covered_entity`.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Local foundation backend — Ollama-compatible endpoint. Best HIPAA story
# for shops without a BAA: PHI never leaves the deployment. Requires
# adequate hardware (Mac mini Pro cluster, single workstation with a
# capable GPU, or an institutional inference server).
# LOCAL_MODEL_ENDPOINT=                     # e.g. http://localhost:11434

# OpenMed Nemotron Privacy Filter backend (on-device, no external API
# calls). NER-based — see recall caveats above. Worth re-benchmarking
# against current foundation backends before defaulting on it for any
# real workload.
# OPENMED_SIDECAR_URL=

# Presidio sidecar (on-device, no external API calls). Regex+NER stack;
# respectable on form-like inputs, weak on clinical narrative.
# PRESIDIO_SIDECAR_URL=
